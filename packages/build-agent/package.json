{
  "name": "blogwright-build-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rolldown -c && node dist/write-manifest.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint src",
    "test": "vitest run",
    "start": "node ./dist/server.js"
  },
  "dependencies": {
    "blogwright-core": "workspace:*",
    "fflate": "^0.8.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "oxlint": "^1.72.0",
    "rolldown": "^1.1.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "description": "HTTP build server baked into the blogwright builder MicroVM image (not published; shipped inside the CLI package)",
  "license": "MIT"
}
